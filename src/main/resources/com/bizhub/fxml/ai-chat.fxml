<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bizhub.controller.AiChatController"
            fx:id="root"
            stylesheets="@../css/theme.css, @../css/user-management.css">

    <left>
        <!-- Controller will swap this include to admin-sidebar.fxml when needed -->
        <fx:include fx:id="sidebarInclude" source="user-sidebar.fxml" />
    </left>

    <top>
        <HBox fx:id="topbar" spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
            <padding>
                <Insets top="14" right="16" bottom="14" left="16" />
            </padding>

            <VBox spacing="2">
                <Text text="AI Assistant" styleClass="h1" />
                <Text text="Chat with BizHub Assistant" styleClass="subtitle" />
            </VBox>

            <Pane HBox.hgrow="ALWAYS" />
            <!-- User profile will be added here programmatically -->
        </HBox>
    </top>

    <center>
        <VBox spacing="0" style="-fx-padding: 20;">
            <!-- Chat Container Card -->
            <VBox styleClass="card" spacing="0" VBox.vgrow="ALWAYS"
                  style="-fx-background-color: rgba(26, 51, 82, 0.98); -fx-background-radius: 16; -fx-border-radius: 16; -fx-border-color: rgba(255, 184, 77, 0.35); -fx-border-width: 1.5;">

                <!-- Chat Header -->
                <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-background-color: linear-gradient(to bottom, #172A45, #0A192F); -fx-background-radius: 16 16 0 0; -fx-border-color: rgba(255, 184, 77, 0.35); -fx-border-width: 0 0 1 0; -fx-padding: 16 20;">
                    <!-- Bot Avatar -->
                    <StackPane style="-fx-background-color: linear-gradient(to bottom right, #FFB84D, #FFD54F); -fx-background-radius: 50%; -fx-padding: 6; -fx-min-width: 48; -fx-min-height: 48; -fx-max-width: 48; -fx-max-height: 48;">
                        <ImageView fitWidth="36" fitHeight="36" preserveRatio="true">
                            <image>
                                <Image url="@../images/site-images/logo.png" />
                            </image>
                        </ImageView>
                    </StackPane>
                    <VBox spacing="2">
                        <Label text="BizHub Assistant" style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold;" />
                        <Label text="🟢 Online - Ready to help" style="-fx-text-fill: #FFB84D; -fx-font-size: 12px;" />
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS" />
                    <Button text="Clear Chat" onAction="#clearChat" styleClass="btn" />
                </HBox>

                <!-- Messages Area -->
                <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER"
                            style="-fx-background-color: #0A192F; -fx-padding: 0;"
                            VBox.vgrow="ALWAYS">
                    <VBox fx:id="messagesContainer" spacing="12" style="-fx-padding: 20; -fx-background-color: #0A192F;">
                        <!-- Welcome Message -->
                        <HBox alignment="TOP_LEFT" spacing="10">
                            <StackPane style="-fx-background-color: linear-gradient(to bottom right, #FFB84D, #FFD54F); -fx-background-radius: 50%; -fx-min-width: 36; -fx-min-height: 36; -fx-max-width: 36; -fx-max-height: 36;">
                                <ImageView fitWidth="28" fitHeight="28" preserveRatio="true">
                                    <image>
                                        <Image url="@../images/site-images/logo.png" />
                                    </image>
                                </ImageView>
                            </StackPane>
                            <VBox style="-fx-background-color: rgba(26, 51, 82, 0.98); -fx-background-radius: 12; -fx-padding: 14; -fx-max-width: 500; -fx-border-color: rgba(255, 184, 77, 0.30); -fx-border-width: 1.5;">
                                <Label text="Hi there! 👋 I'm your BizHub navigation assistant." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #FFFFFF;" />
                                <Label text="I can help you navigate around the app, answer questions about formations, reviews, and more." wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #FFFFFF; -fx-padding: 8 0 0 0;" />
                                <Label text="Type 'help' to see what I can do!" wrapText="true" style="-fx-font-size: 14px; -fx-text-fill: #FFB84D; -fx-padding: 8 0 0 0;" />
                            </VBox>
                        </HBox>
                    </VBox>
                </ScrollPane>

                <!-- Input Area -->
                <HBox spacing="12" alignment="CENTER" style="-fx-background-color: #172A45; -fx-padding: 16 20; -fx-border-color: rgba(255, 184, 77, 0.35); -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 16 16;">
                    <TextField fx:id="inputField" promptText="Type your message here..."
                               style="-fx-background-color: rgba(10, 25, 47, 0.70); -fx-background-radius: 24; -fx-border-radius: 24; -fx-border-color: rgba(42, 74, 111, 0.85); -fx-border-width: 1.5; -fx-padding: 12 18; -fx-font-size: 14px; -fx-text-fill: #FFFFFF; -fx-prompt-text-fill: #FFB84D;"
                               HBox.hgrow="ALWAYS" />
                    <Button fx:id="sendButton" text="Send ➤" onAction="#onSendMessage"
                            style="-fx-background-color: linear-gradient(to bottom, #FFD54F, #FFB84D); -fx-text-fill: #0A192F; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12 24; -fx-background-radius: 24;" />
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
