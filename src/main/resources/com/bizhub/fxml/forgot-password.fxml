<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.bizhub.controller.users_avis.user.ForgotPasswordController"
           stylesheets="@../css/theme.css">

    <!-- Background gradient -->
    <Pane styleClass="bg-gradient" />

    <VBox alignment="CENTER" spacing="20" maxWidth="480" styleClass="card">
        <padding>
            <Insets top="32" right="32" bottom="32" left="32" />
        </padding>

        <!-- Logo and Brand -->
        <VBox alignment="CENTER" spacing="8">
            <ImageView fitHeight="56" fitWidth="56" preserveRatio="true" styleClass="logo-image">
                <image>
                    <Image url="@../images/site-images/logo.png" />
                </image>
            </ImageView>
            <Text text="BizHub" styleClass="brand-title" />
        </VBox>

        <!-- Step 1: Enter Email -->
        <VBox fx:id="emailSection" spacing="16" alignment="CENTER">
            <VBox spacing="4" alignment="CENTER">
                <Text text="Forgot Password?" styleClass="h1" />
                <Text text="Enter your email to receive a reset code" styleClass="subtitle"
                      wrappingWidth="350" textAlignment="CENTER" />
            </VBox>

            <Separator opacity="0.25" />

            <VBox spacing="14">
                <VBox spacing="6">
                    <Label text="Email Address" styleClass="field-label" />
                    <TextField fx:id="emailField" promptText="you@bizhub.tn" styleClass="text-field-modern" />
                </VBox>

                <Button fx:id="sendCodeButton" text="Send Reset Code" onAction="#onSendCode"
                        maxWidth="1.7976931348623157E308" styleClass="btn-primary" />
            </VBox>
        </VBox>

        <!-- Step 2: Enter Code -->
        <VBox fx:id="codeSection" spacing="16" alignment="CENTER" visible="false" managed="false">
            <VBox spacing="4" alignment="CENTER">
                <Text text="Enter Reset Code" styleClass="h1" />
                <Text fx:id="codeSentText" text="We sent a 6-digit code to your email"
                      styleClass="subtitle" wrappingWidth="350" textAlignment="CENTER" />
            </VBox>

            <Separator opacity="0.25" />

            <VBox spacing="14">
                <HBox alignment="CENTER" spacing="8">
                    <TextField fx:id="codeField1" prefWidth="50" styleClass="pin-field" />
                    <TextField fx:id="codeField2" prefWidth="50" styleClass="pin-field" />
                    <TextField fx:id="codeField3" prefWidth="50" styleClass="pin-field" />
                    <TextField fx:id="codeField4" prefWidth="50" styleClass="pin-field" />
                    <TextField fx:id="codeField5" prefWidth="50" styleClass="pin-field" />
                    <TextField fx:id="codeField6" prefWidth="50" styleClass="pin-field" />
                </HBox>

                <Button fx:id="verifyCodeButton" text="Verify Code" onAction="#onVerifyCode"
                        maxWidth="1.7976931348623157E308" styleClass="btn-primary" />

                <HBox spacing="8" alignment="CENTER">
                    <Label text="Didn't receive it?" styleClass="hint" />
                    <Hyperlink text="Resend code" onAction="#onResendCode" />
                </HBox>
            </VBox>
        </VBox>

        <!-- Step 3: New Password -->
        <VBox fx:id="passwordSection" spacing="16" alignment="CENTER" visible="false" managed="false">
            <VBox spacing="4" alignment="CENTER">
                <Text text="Set New Password" styleClass="h1" />
                <Text text="Create a strong, secure password" styleClass="subtitle"
                      wrappingWidth="350" textAlignment="CENTER" />
            </VBox>

            <Separator opacity="0.25" />

            <VBox spacing="14">
                <VBox spacing="6">
                    <Label text="New Password" styleClass="field-label" />
                    <PasswordField fx:id="newPasswordField" promptText="Min 6 characters" styleClass="text-field-modern" />
                </VBox>

                <VBox spacing="6">
                    <Label text="Confirm Password" styleClass="field-label" />
                    <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" styleClass="text-field-modern" />
                </VBox>

                <Button fx:id="resetPasswordButton" text="Reset Password" onAction="#onResetPassword"
                        maxWidth="1.7976931348623157E308" styleClass="btn-primary" />
            </VBox>
        </VBox>

        <!-- Success Section -->
        <VBox fx:id="successSection" spacing="16" alignment="CENTER" visible="false" managed="false">
            <Text text="🎉" style="-fx-font-size: 48px;" />
            <Text text="Password Reset!" styleClass="h1" />
            <Text text="Your password has been successfully changed." styleClass="subtitle"
                  wrappingWidth="350" textAlignment="CENTER" />

            <Button text="Back to Login" onAction="#onBackToLogin" styleClass="btn-primary" />
        </VBox>

        <!-- Status/Error Label -->
        <Label fx:id="statusLabel" wrapText="true" textAlignment="CENTER" />

        <!-- Progress Indicator -->
        <ProgressIndicator fx:id="progressIndicator" visible="false" prefWidth="30" prefHeight="30" />

        <!-- Back to Login Link -->
        <HBox fx:id="backToLoginBox" spacing="8" alignment="CENTER">
            <Label text="Remember your password?" styleClass="hint" />
            <Hyperlink text="Back to login" onAction="#onBackToLogin" />
        </HBox>
    </VBox>
</StackPane>

