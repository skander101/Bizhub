<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bizhub.controller.investissement.DealPipelineController"
            stylesheets="@../css/theme.css">

    <left>
        <fx:include fx:id="sidebar" source="sidebar.fxml"/>
    </left>

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                <image><Image url="@../images/site-images/logo.png"/></image>
            </ImageView>
            <VBox spacing="2">
                <Text text="Deal Pipeline" styleClass="h1"/>
                <Text text="Payment → Contract → Signature → Confirmation" styleClass="subtitle"/>
            </VBox>
            <Pane HBox.hgrow="ALWAYS"/>
            <ProgressIndicator fx:id="loadingSpinner" prefWidth="28" prefHeight="28" visible="false"/>
            <Button text="Back" onAction="#handleBack" styleClass="btn"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="20" fillWidth="true">
                <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>

                <!-- Deal Summary Card -->
                <HBox spacing="20" alignment="CENTER_LEFT" styleClass="card" style="-fx-border-color: rgba(232,169,58,0.40);">
                    <VBox spacing="4">
                        <Label fx:id="dealTitleLabel" text="Project"
                               style="-fx-text-fill: #FFFFFF; -fx-font-size: 20px; -fx-font-weight: 900;"/>
                        <HBox spacing="12">
                            <Label fx:id="dealAmountLabel" text="0 EUR"
                                   style="-fx-text-fill: #FDB813; -fx-font-size: 16px; -fx-font-weight: 800;"/>
                            <Label fx:id="dealStatusLabel" text="PENDING"
                                   styleClass="badge badge-gold"/>
                        </HBox>
                    </VBox>
                    <Pane HBox.hgrow="ALWAYS"/>
                    <ProgressBar fx:id="pipelineProgress" prefWidth="250" prefHeight="8" progress="0"
                                 style="-fx-accent: #E8A93A;"/>
                </HBox>

                <!-- Status Message -->
                <Label fx:id="statusMessageLabel" text="" wrapText="true"
                       style="-fx-text-fill: #FDB813; -fx-font-size: 13px; -fx-padding: 0 8;"/>

                <!-- Pipeline Steps -->
                <HBox spacing="16" fillHeight="true">

                    <!-- Step 1: Payment -->
                    <VBox fx:id="step1Box" spacing="12" HBox.hgrow="ALWAYS" styleClass="card"
                          style="-fx-min-height: 200;">
                        <Label text="STEP 1" style="-fx-text-fill: rgba(232,169,58,0.6); -fx-font-size: 10px; -fx-font-weight: 900;"/>
                        <Label text="Payment" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                        <Label text="Secure payment via Stripe" style="-fx-text-fill: #E8A93A; -fx-font-size: 12px;" wrapText="true"/>
                        <Pane VBox.vgrow="ALWAYS"/>
                        <Label fx:id="step1Status" text="PENDING" style="-fx-text-fill: rgba(232,169,58,0.5); -fx-font-weight: 800;"/>
                        <Button fx:id="processPaymentBtn" text="Process Payment" onAction="#handleProcessPayment"
                                styleClass="btn-primary" maxWidth="Infinity"/>
                    </VBox>

                    <!-- Step 2: Contract -->
                    <VBox fx:id="step2Box" spacing="12" HBox.hgrow="ALWAYS" styleClass="card"
                          style="-fx-min-height: 200;">
                        <Label text="STEP 2" style="-fx-text-fill: rgba(232,169,58,0.6); -fx-font-size: 10px; -fx-font-weight: 900;"/>
                        <Label text="Contract" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                        <Label text="Generate PDF contract" style="-fx-text-fill: #E8A93A; -fx-font-size: 12px;" wrapText="true"/>
                        <Pane VBox.vgrow="ALWAYS"/>
                        <Label fx:id="step2Status" text="PENDING" style="-fx-text-fill: rgba(232,169,58,0.5); -fx-font-weight: 800;"/>
                        <Button fx:id="generateContractBtn" text="Generate Contract" onAction="#handleGenerateContract"
                                styleClass="btn-primary" maxWidth="Infinity" disable="true"/>
                        <Button fx:id="reviewContractBtn" text="AI Review Contract" onAction="#handleReviewContract"
                                style="-fx-background-color: #06B6D422; -fx-text-fill: #06B6D4; -fx-font-weight: 800;
                                       -fx-background-radius: 10; -fx-border-color: #06B6D444; -fx-border-radius: 10;
                                       -fx-border-width: 1; -fx-cursor: hand; -fx-font-size: 11px;"
                                maxWidth="Infinity" disable="true"/>
                    </VBox>

                    <!-- Step 3: Signature -->
                    <VBox fx:id="step3Box" spacing="12" HBox.hgrow="ALWAYS" styleClass="card"
                          style="-fx-min-height: 200;">
                        <Label text="STEP 3" style="-fx-text-fill: rgba(232,169,58,0.6); -fx-font-size: 10px; -fx-font-weight: 900;"/>
                        <Label text="Digital Signature" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                        <Label text="Sign via Yousign" style="-fx-text-fill: #E8A93A; -fx-font-size: 12px;" wrapText="true"/>
                        <Pane VBox.vgrow="ALWAYS"/>
                        <Label fx:id="step3Status" text="PENDING" style="-fx-text-fill: rgba(232,169,58,0.5); -fx-font-weight: 800;"/>
                        <Button fx:id="sendSignatureBtn" text="Send for Signature" onAction="#handleSendSignature"
                                styleClass="btn-primary" maxWidth="Infinity" disable="true"/>
                    </VBox>

                    <!-- Step 4: Email -->
                    <VBox fx:id="step4Box" spacing="12" HBox.hgrow="ALWAYS" styleClass="card"
                          style="-fx-min-height: 200;">
                        <Label text="STEP 4" style="-fx-text-fill: rgba(232,169,58,0.6); -fx-font-size: 10px; -fx-font-weight: 900;"/>
                        <Label text="Confirmation" style="-fx-text-fill: #FFFFFF; -fx-font-size: 18px; -fx-font-weight: 900;"/>
                        <Label text="Email confirmation to both parties" style="-fx-text-fill: #E8A93A; -fx-font-size: 12px;" wrapText="true"/>
                        <Pane VBox.vgrow="ALWAYS"/>
                        <Label fx:id="step4Status" text="PENDING" style="-fx-text-fill: rgba(232,169,58,0.5); -fx-font-weight: 800;"/>
                        <Button fx:id="sendEmailBtn" text="Send Confirmation" onAction="#handleSendEmail"
                                styleClass="btn-primary" maxWidth="Infinity" disable="true"/>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
