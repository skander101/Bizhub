<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bizhub.controller.investissement.AIDemoController"
            stylesheets="@../css/theme.css, @../css/user-management.css">

    <!-- SIDEBAR -->
    <left>
        <fx:include fx:id="sidebar" source="sidebar.fxml"/>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #0A192F;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="topbar">
                <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                <Label text="🤖 Plateforme IA BizHub" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #FFB84D;"/>
                <Label text="Systèmes Intelligents d'Investissement" style="-fx-font-size: 13; -fx-text-fill: rgba(255,184,77,0.65);"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Rafraîchir tout" onAction="#loadRecommendations" styleClass="nav-button"/>
                <Button text="💰 Simuler Investissement IA" onAction="#simulateInvestmentWithAI" styleClass="primary-button"/>
            </HBox>

            <!-- TabPane principal -->
            <TabPane fx:id="aiTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                <!-- Onglet Recommandations -->
                <Tab fx:id="recommendationsTab" text="🎯 Recommandations Intelligentes" closable="false">
                    <content>
                        <VBox spacing="10" style="-fx-padding: 20;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <children>
                                        <Label text="Projets Recommandés Pour Vous" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                                        <Label fx:id="recommendationStatusLabel" text="Chargement..." style="-fx-text-fill: #666;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button fx:id="refreshRecommendationsBtn" text="🔄 Actualiser" styleClass="nav-button"/>
                                    </children>
                                </HBox>
                                <ListView fx:id="recommendationsListView" VBox.vgrow="ALWAYS"
                                         style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e0e0;"/>
                                <HBox style="-fx-background-color: #e8f5e8; -fx-padding: 10; -fx-background-radius: 5;">
                                    <children>
                                        <Label text="💡 Les recommandations sont basées sur:" style="-fx-font-weight: bold;"/>
                                        <Label text="Votre secteur d'investissement, budget, expérience, et tendances du marché"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </Tab>

                <!-- Onglet Chatbot -->
                <Tab fx:id="chatbotTab" text="💬 Assistant Investisseur" closable="false">
                    <content>
                        <VBox spacing="10" style="-fx-padding: 20;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15">
                                    <children>
                                        <Label text="Assistant IA - Questions/Réponses" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                                        <Circle radius="8" style="-fx-fill: #4caf50;"/>
                                        <Label text="En ligne" style="-fx-text-fill: #4caf50;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                    </children>
                                </HBox>
                                <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS"
                                           style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e0e0;">
                                    <content>
                                        <VBox fx:id="chatMessagesContainer" spacing="10" style="-fx-padding: 15;"/>
                                    </content>
                                </ScrollPane>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <children>
                                        <Label text="Actions rapides:" style="-fx-font-weight: bold;"/>
                                        <ListView fx:id="quickActionsListView" prefHeight="40" prefWidth="400"
                                                 orientation="HORIZONTAL" style="-fx-background-color: transparent;"/>
                                    </children>
                                </HBox>
                                <HBox spacing="10" alignment="CENTER">
                                    <children>
                                        <TextField fx:id="chatInputField" promptText="Tapez votre question ici..."
                                                  HBox.hgrow="ALWAYS" style="-fx-background-radius: 20; -fx-border-radius: 20; -fx-padding: 10;"/>
                                        <Button fx:id="sendMessageBtn" text="Envoyer ▶"
                                               style="-fx-background-color: #2196f3; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 20;"/>
                                    </children>
                                </HBox>
                                <HBox style="-fx-background-color: #e3f2fd; -fx-padding: 10; -fx-background-radius: 5;">
                                    <children>
                                        <Label text="💬 Essayez de demander:" style="-fx-font-weight: bold;"/>
                                        <Label text="• 'Quels projets me recommandez-vous?' • 'Comment investir?' • 'Quel est mon budget?'"/>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </Tab>

                <!-- Onglet Détection de Fraude -->
                <Tab fx:id="fraudDetectionTab" text="🔍 Sécurité &amp; Détection de Fraude" closable="false">
                    <content>
                        <HBox spacing="15" style="-fx-padding: 20;">
                            <children>
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="15">
                                            <children>
                                                <Label text="Centre de Sécurité" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                                                <Region HBox.hgrow="ALWAYS"/>
                                                <Button fx:id="refreshFraudDataBtn" text="🔄 Actualiser"
                                                       style="-fx-background-color: #ffebee; -fx-text-fill: #c62828;"/>
                                            </children>
                                        </HBox>
                                        <VBox style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #e0e0e0;">
                                            <children>
                                                <Label text="📊 Statistiques de Détection" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                                                <Label fx:id="fraudStatisticsLabel" text="Chargement..." wrapText="true"
                                                      style="-fx-text-fill: #666; -fx-font-size: 12;"/>
                                            </children>
                                        </VBox>
                                        <Label text="🚨 Alertes Récentes" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                                        <ListView fx:id="fraudAlertsListView" VBox.vgrow="ALWAYS"
                                                 style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #e0e0e0;"/>
                                    </children>
                                </VBox>
                                <VBox spacing="10" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label text="📋 Détails de l'Alerte" style="-fx-font-weight: bold; -fx-font-size: 14;"/>
                                        <TextArea fx:id="fraudDetailsArea" editable="false" wrapText="true"
                                                 VBox.vgrow="ALWAYS" style="-fx-background-color: #fafafa; -fx-font-family: monospace; -fx-font-size: 11;"/>
                                        <VBox style="-fx-background-color: #fff3e0; -fx-padding: 15; -fx-background-radius: 10;">
                                            <children>
                                                <Label text="🛡️ Actions de Sécurité" style="-fx-font-weight: bold;"/>
                                                <Button text="⚠️ Marquer comme faux positif" style="-fx-background-color: #fff3e0; -fx-text-fill: #e65100;"/>
                                                <Button text="🔔 Escalader l'alerte" style="-fx-background-color: #ffebee; -fx-text-fill: #c62828;"/>
                                                <Button text="✅ Résoudre l'alerte" style="-fx-background-color: #e8f5e8; -fx-text-fill: #2e7d32;"/>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </content>
                </Tab>

            </TabPane>

            <!-- Pied de page -->
            <HBox alignment="CENTER" spacing="20" styleClass="topbar">
                <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                <Label text="🤖 Systèmes IA actifs" style="-fx-text-fill: #4caf50; -fx-font-weight: bold;"/>
                <Label text="• Recommandation personnalisée" style="-fx-text-fill: rgba(255,184,77,0.65);"/>
                <Label text="• Chatbot intelligent" style="-fx-text-fill: rgba(255,184,77,0.65);"/>
                <Label text="• Détection de fraude temps réel" style="-fx-text-fill: rgba(255,184,77,0.65);"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Dernière mise à jour: Maintenant" style="-fx-text-fill: rgba(255,184,77,0.45);"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
