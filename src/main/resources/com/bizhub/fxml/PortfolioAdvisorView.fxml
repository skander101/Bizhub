<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.bizhub.controller.investissement.PortfolioAdvisorController"
            stylesheets="@../css/theme.css, @../css/user-management.css">

    <left>
        <fx:include fx:id="sidebar" source="sidebar.fxml"/>
    </left>

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
            <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
            <ImageView fitHeight="40" fitWidth="40" preserveRatio="true">
                <image><Image url="@../images/site-images/logo.png"/></image>
            </ImageView>
            <VBox spacing="1">
                <Text text="AI Portfolio Advisor" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-fill: #E8A93A;"/>
                <Text text="AI-powered portfolio insights and rebalancing suggestions" style="-fx-font-size: 11px; -fx-fill: rgba(200,200,200,0.6);"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="refreshBtn" text="Refresh Analysis" onAction="#handleRefresh"
                    style="-fx-background-color: #06B6D4; -fx-text-fill: white; -fx-font-weight: 800;
                           -fx-background-radius: 12; -fx-padding: 8 20; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <VBox fx:id="mainContent" spacing="20" style="-fx-padding: 20 24 30 24;">

                <!-- Health + Score Cards Row -->
                <HBox fx:id="scoreCardsRow" spacing="16" alignment="CENTER">
                    <!-- Filled dynamically -->
                </HBox>

                <!-- Sector Allocation Chart + Status Breakdown -->
                <HBox spacing="16">
                    <VBox HBox.hgrow="ALWAYS" spacing="10"
                          style="-fx-background-color: rgba(26,51,82,0.96); -fx-background-radius: 18;
                                 -fx-border-color: rgba(6,182,212,0.12); -fx-border-radius: 18; -fx-border-width: 1;
                                 -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 4);">
                        <Label text="SECTOR ALLOCATION" style="-fx-text-fill: #06B6D4; -fx-font-size: 12px;
                               -fx-font-weight: 900; -fx-letter-spacing: 1.5;"/>
                        <PieChart fx:id="sectorChart" prefHeight="260" legendVisible="true"
                                  style="-fx-legend-side: bottom;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="10"
                          style="-fx-background-color: rgba(26,51,82,0.96); -fx-background-radius: 18;
                                 -fx-border-color: rgba(6,182,212,0.12); -fx-border-radius: 18; -fx-border-width: 1;
                                 -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 4);">
                        <Label text="STATUS BREAKDOWN" style="-fx-text-fill: #06B6D4; -fx-font-size: 12px;
                               -fx-font-weight: 900; -fx-letter-spacing: 1.5;"/>
                        <PieChart fx:id="statusChart" prefHeight="260" legendVisible="true"
                                  style="-fx-legend-side: bottom;"/>
                    </VBox>
                </HBox>

                <!-- Holdings Table -->
                <VBox spacing="10"
                      style="-fx-background-color: rgba(26,51,82,0.96); -fx-background-radius: 18;
                             -fx-border-color: rgba(232,169,58,0.12); -fx-border-radius: 18; -fx-border-width: 1;
                             -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 4);">
                    <Label text="YOUR HOLDINGS" style="-fx-text-fill: #E8A93A; -fx-font-size: 12px;
                           -fx-font-weight: 900; -fx-letter-spacing: 1.5;"/>
                    <VBox fx:id="holdingsContainer" spacing="8"/>
                </VBox>

                <!-- AI Advice Section -->
                <VBox spacing="10"
                      style="-fx-background-color: rgba(26,51,82,0.96); -fx-background-radius: 18;
                             -fx-border-color: rgba(6,182,212,0.18); -fx-border-radius: 18; -fx-border-width: 1;
                             -fx-padding: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 12, 0, 0, 4);">
                    <Label text="AI PORTFOLIO ADVICE" style="-fx-text-fill: #06B6D4; -fx-font-size: 12px;
                           -fx-font-weight: 900; -fx-letter-spacing: 1.5;"/>
                    <ProgressIndicator fx:id="aiSpinner" prefWidth="36" prefHeight="36" visible="false"/>
                    <VBox fx:id="adviceContainer" spacing="12"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
